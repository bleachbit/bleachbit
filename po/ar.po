msgstr "خطأ: {operation_option}: {command}"

#. TRANSLATORS: 'empty' means 'unallocated'
#: ../bleachbit/Worker.py
msgid "Please wait. Wiping empty space."
msgstr "الرجاء الانتظار. جارٍ محو المساحة الفارغة."

#: ../bleachbit/Worker.py
msgid "To stop this process, press the abort button on the toolbar and wait."
msgstr "لإيقاف العملية، اضغط على زر 'إلغاء' في شريط الأدوات وانتظر."

#: ../bleachbit/Worker.py
msgid ""
"If the application is force closed before the process is complete, large "
"files may remain on the disk, and they may use all available space. To "
"remove them, start BleachBit again."
msgstr ""
"إذا تم إجبار التطبيق على التوقف قبل إكمال العملية، قد تبقى بعض الملفات "
"الكبيرة على القرص، وقد تستخدم كل المساحة المتاحة. لحذفها، ابدأ BleachBit من "
"جديد."

