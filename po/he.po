msgid "Importing cleaners from Winapp2.ini…"
msgstr "מנקים מיובאים מ־Winapp2.ini…"

#: ../bleachbit/Cleaner.py
#, python-format
msgid "Wipe empty space %s"
msgstr "מחיקה מוחלטת של השטח הריק %s"

