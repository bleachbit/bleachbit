msgstr "%(device)s takas dosyası için UUID %(uuid)s bulundu."

#. TRANSLATORS: The variable is a quantity like 5kB
#: ../bleachbit/Memory.py
#, python-format
msgid "Physical free memory is %s."
msgstr "Fiziksel boş bellek: %s."

#. TRANSLATORS: The variable is a device like /dev/sda2
#: ../bleachbit/Memory.py
#, python-format
msgid "Wiping the swap device %s."
msgstr "%s takas aygıtı siliniyor."

#. TRANSLATORS: The variable is a device like /dev/sda2
#: ../bleachbit/Memory.py
#, python-format
msgid "Reinitializing the swap device %s."
msgstr "%s takas aygıtı yeniden başlatılıyor."

#. TRANSLATORS: The variable is a device like /dev/sda2
