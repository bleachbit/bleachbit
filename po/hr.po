#: ../bleachbit/Winapp.py
msgid "Games"
msgstr "Igre"

#: ../bleachbit/Winapp.py
msgid "Imported from winapp2.ini"
msgstr "Uvezeno iz winapp2.ini"

#: ../bleachbit/Windows.py
msgid "Administrator privileges are required to clean Windows Updates"
msgstr "Za čišćenje ažuriranja sustava Windows potrebne su administratorske ovlasti"

#. TRANSLATORS: Message in log file when stopping a Windows service.
#. The placeholder is the code name of the service.
#: ../bleachbit/Windows.py
#, python-format
msgid "stop Windows service %(service)s"
msgstr "zaustavi Windows servis %(service)s"

#. TRANSLATORS: Message in log file when starting a Windows service.
#. The placeholder is the code name of the service.
#: ../bleachbit/Windows.py
#, python-format
msgid "start Windows service %(service)s"
msgstr "pokreni Windows servis %(service)s"

#: ../bleachbit/Wipe.py
msgid ""
"There was at least one file on a file system that does not support advanced "
"overwriting."
msgstr "Pronađena je najmanje jedna datoteka na datotečnom sustavu koji ne podržava napredno prebrisivanje."

#. TRANSLATORS: Debug log message shown during file wiping. 'Wiping' is a
#. present participle (ongoing action) refering to secure overwrite.
#. %(pathname)s is the file/directory path; %(fstype)s is the file system type
#. (e.g., ext3, ntfs). Do not translate placeholders.
#: ../bleachbit/Wipe.py
#, python-format
msgid "Wiping path %(pathname)s with file system type %(fstype)s"
msgstr "Prebrisivanje putanje %(pathname)s na datotečnom sustavu vrste %(fstype)s"

#: ../bleachbit/Wipe.py
#, python-format
msgid "Path to wipe must be an existing directory: %s"
msgstr "Putanja za prebrisivanje mora biti postojeća mapa: %s"

#: ../bleachbit/Wipe.py
msgid "Creating new, temporary file for wiping free space."
msgstr "Izrada nove privremene datoteke za prebrisivanje slobodnog prostora."

#: ../bleachbit/Wipe.py
#, python-format
msgid "Error #%d when flushing the file buffer."
msgstr "Pogreška #%d pri pražnjenju međuspremnika datoteke."

#. TRANSLATORS: Debug message summarizing a write operation. All placeholders
#. are numeric: %(file_count)d = integer number of files written;
#. %(total_bytes)d = integer total bytes written; %(elapsed_sec)d = integer
#. elapsed seconds; %(rate_mbs).2f = decimal megabytes per second (e.g., 3.14).
#. Do not translate variables.
#: ../bleachbit/Wipe.py
#, python-format
msgid ""
"Wrote %(file_count)d files and %(total_bytes)d bytes in %(elapsed_sec)d "
"seconds at %(rate_mbs).2f MB/s"
msgstr "Zapisano je %(file_count)d datoteka i %(total_bytes)d bajtova u %(elapsed_sec)d sekundi brzinom %(rate_mbs).2f MB/s"

#. TRANSLATORS: Debug message showing disk space available to regular (non-root) users.
#. %(bytes)d is an integer count of bytes free; %(inodes)d is an integer count of inodes free.
#. Do not translate variables.
#: ../bleachbit/Wipe.py
#, python-format
msgid "%(bytes)d bytes and %(inodes)d inodes available to non-super-user"
msgstr "Dostupno korisniku bez superkorisničkih ovlasti: %(bytes)d bajtova i %(inodes)d inodeova"

#. TRANSLATORS: Debug message showing disk space available to the root (admin) user.
#. %(bytes)d is an integer count of bytes free; %(inodes)d is an integer count of inodes free.
#. Do not translate variables.
#: ../bleachbit/Wipe.py
#, python-format
msgid "%(bytes)d bytes and %(inodes)d inodes available to super-user"
msgstr "Dostupno superkorisniku: %(bytes)d bajtova i %(inodes)d inodeova"

#: ../bleachbit/Wipe.py
msgid "Encountered unknown error #0 while truncating file."
msgstr "Pojavila se nepoznata pogreška #0 pri skraćivanju datoteke."

#. TRANSLATORS: This indicates an error.  The special keyword
#. %(operation)s will be replaced by 'firefox' or 'opera' or
#. some other cleaner ID.  The special keyword %(msg)s will be
#. replaced by a message such as 'Permission denied.'
#: ../bleachbit/Worker.py
#, python-format
msgid "Exception while running operation '%(operation)s': '%(msg)s'"
msgstr "Iznimka pri izvođenju radnje '%(operation)s': '%(msg)s'"

#: ../bleachbit/Worker.py
#, python-format
msgid "File not found: %s"
msgstr "Datoteka nije pronađena: %s"

#: ../bleachbit/Worker.py
#, python-format
msgid "Access denied when flagging file for later delete: %s"
msgstr "Pristup je odbijen pri označavanju datoteke za kasnije brisanje: %s"

#: ../bleachbit/Worker.py
#, python-format
msgid "Access denied when deleting registry value: %s"
msgstr "Pristup je odbijen pri brisanju vrijednosti registra: %s"

#: ../bleachbit/Worker.py
#, python-format
msgid "Access denied when deleting registry key: %s"
msgstr "Pristup je odbijen pri brisanju ključa registra: %s"

#: ../bleachbit/Worker.py
#, python-format
msgid "Access denied: %s"
msgstr "Pristup je odbijen: %s"

#: ../bleachbit/Worker.py
#, python-brace-format
msgid "Error: {operation_option}: {command}"
msgstr "Pogreška: {operation_option}: {command}"

#. TRANSLATORS: 'empty' means 'unallocated'
#: ../bleachbit/Worker.py
msgid "Please wait. Wiping empty space."
msgstr "Pričekajte. Prebrisuje se slobodan prostor."

#: ../bleachbit/Worker.py
msgid "To stop this process, press the abort button on the toolbar and wait."
msgstr "Za zaustavljanje ovog postupka pritisnite gumb za prekid na alatnoj traci i pričekajte."

#: ../bleachbit/Worker.py
msgid ""
"If the application is force closed before the process is complete, large "
"files may remain on the disk, and they may use all available space. To "
"remove them, start BleachBit again."
msgstr "Ako se aplikacija prisilno zatvori prije dovršetka postupka, velike datoteke mogu ostati na disku i zauzeti sav raspoloživ prostor. Da biste ih uklonili, ponovno pokrenite BleachBit."

#. TRANSLATORS: %s is replaced with Firefox, System, etc.
#: ../bleachbit/Worker.py
#, python-format
msgid "Please wait.  Cleaning %s."
msgstr "Pričekajte. Čisti se %s."

#: ../bleachbit/Worker.py
#, python-format
msgid "About %d minute remaining."
msgid_plural "About %d minutes remaining."
msgstr[0] "Preostala je približno %d minuta."
msgstr[1] "Preostale su približno %d minute."
msgstr[2] "Preostalo je približno %d minuta."

#. TRANSLATORS: This refers to disk space that was
#. really recovered (in other words, not a preview)
#: ../bleachbit/Worker.py
#, python-format
msgid "Disk space recovered: %s"
msgstr "Oslobođeni prostor na disku: %s"

#. TRANSLATORS: This refers to a preview (no real
#. changes were made yet)
#: ../bleachbit/Worker.py
#, python-format
msgid "Disk space to be recovered: %s"
msgstr "Prostor na disku koji će se osloboditi: %s"

#. TRANSLATORS: This refers to the number of files really
#. deleted (in other words, not a preview).
#: ../bleachbit/Worker.py
#, python-format
msgid "Files deleted: %d"
msgstr "Izbrisane datoteke: %d"

#. TRANSLATORS: This refers to the number of files that
#. would be deleted (in other words, simply a preview).
#: ../bleachbit/Worker.py
#, python-format
msgid "Files to be deleted: %d"
msgstr "Datoteke za brisanje: %d"

#: ../bleachbit/Worker.py
#, python-format
msgid "Special operations: %d"
msgstr "Posebne radnje: %d"

#: ../bleachbit/Worker.py
#, python-format
msgid "Errors: %d"
msgstr "Pogreške: %d"

#. TRANSLATORS: The "deep scan" feature searches over broad
#. areas of the file system such as the user's whole home directory
#. or all the system executables.
#: ../bleachbit/Worker.py
msgid "Please wait.  Running deep scan."
msgstr "Pričekajte. Izvodi se dubinsko skeniranje."

#. TRANSLATORS: %s is replaced with Firefox, System, etc.
#: ../bleachbit/Worker.py
#, python-format
msgid "Please wait.  Previewing %s."
msgstr "Pričekajte. Izrada pretpregleda za %s."

#. TRANSLATORS: This menu item opens a file picker dialog where the
#. user can select one or more files. The selected files are then
#. securely deleted by overwriting their data before removal, making
#. recovery impossible. "Shredding" refers to this secure deletion process.
#: ../share/app-menu.ui
msgid "_Shred Files"
msgstr "_Nepovratno izbriši datoteke"

#. TRANSLATORS: This menu item prompts the user to select one or
#. more folders using a folder picker dialog. Then, it securely deletes
#. the selected folder(s) and all their contents. "Shredding" means
#. overwriting data before deletion to prevent recovery.
#: ../share/app-menu.ui
msgid "Sh_red Folders"
msgstr "Nep_ovratno izbriši mape"

#. TRANSLATORS: This menu item reads file or folder paths from the
#. clipboard, then securely deletes them. "Shredding" means overwriting
#. data before deletion to prevent recovery. The clipboard is cleared
#. after the operation.
#: ../share/app-menu.ui
msgid "Shred Paths from Clipboard"
msgstr "Nepovratno izbriši putanje iz međuspremnika"

#. TRANSLATORS: This menu item prompts the user to select a folder.
#. It then fills the partition with data until full, overwriting any
#. recoverable traces of previously deleted files. "Empty space" refers
#. to unallocated disk space where deleted file data may still exist.
#: ../share/app-menu.ui
msgid "_Wipe Empty Space"
msgstr "_Prebriši slobodan prostor"

#. TRANSLATORS: This menu item creates decoy files filled with random
#. data to mislead anyone searching for sensitive information. "Chaff" refers
#. to material used as a distraction or decoy.
#: ../share/app-menu.ui
msgid "_Make Chaff"
msgstr "_Izradi lažne datoteke"

#. TRANSLATORS: This menu item securely deletes the application's
#. configuration files (resetting all settings to defaults) and then
#. closes the application. "Shredding" means overwriting data before
#. deletion to prevent recovery.
#: ../share/app-menu.ui
msgid "S_hred Settings and Quit"
msgstr "Nep_ovratno izbriši postavke i izađi"

#. TRANSLATORS: This menu item displays technical details about
#. the system, sometimes useful for troubleshooting issues.
#: ../share/app-menu.ui
msgid "S_ystem Information"
msgstr "Informacije o _sustavu"

#. TRANSLATORS: This menu item opens a web browser to a page
#. with links to documentation and the bug tracker.
#: ../share/app-menu.ui
msgid "_Help"
msgstr "_Pomoć"

#. TRANSLATORS: This menu item opens a dialog with general information
#. about the application, including its name, version, description,
#. copyright, license, and website link.
#: ../share/app-menu.ui
msgid "_About BleachBit"
msgstr "_O BleachBitu"
