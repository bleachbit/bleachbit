#: windows/NsisInclude/NsisMultiUserLang.nsh
msgctxt "nsis:MULTIUSER_ALL_USERS_UMUI"
msgid "For anyone who uses this computer (all users)"
msgstr "Za svakoga tko koristi ovo računalo (svi korisnici)"

