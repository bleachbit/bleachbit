#. TRANSLATORS: Button label on the headerbar and context menu item
#. in the treeview.
#. 'Clean' is a verb.
#: ../bleachbit/GuiWindow.py
msgid "Clean"
msgstr "Očisti"

#. TRANSLATORS: Button in tree view's context menu to open the cookie
