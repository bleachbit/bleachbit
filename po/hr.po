msgstr "Dodaj mapu"

#. TRANSLATORS: "Expert Mode" is the name of a feature/setting found in
#. Preferences. Keep it consistent with the translation of "Expert Mode"
#. in the preferences dialog. This message appears when cleaning options
#. with warnings are selected but expert mode is disabled.
#: ../bleachbit/GuiStartup.py
msgid ""
"One or more selected cleaning options have warnings and require Expert Mode "
"to clean. Enable it in preferences."
msgstr "Jedna ili više odabranih opcija čišćenja imaju upozorenja i za čišćenje zahtijevaju stručni način rada. Omogućite ga u postavkama."

#. TRANSLATORS: "Expert Mode" is the name of a feature/setting found in
#. Preferences. Keep it consistent with the translation of "Expert Mode"
#. in the preferences dialog. This message appears when the user tries to
#. skip a delete confirmation without enabling Expert Mode.
#: ../bleachbit/GuiStartup.py
msgid ""
"Delete confirmation is disabled but expert mode is not enabled. Enable "
"Expert Mode in preferences to skip delete confirmations."
msgstr "Potvrda brisanja onemogućena je, ali stručni način rada nije omogućen. Omogućite stručni način rada u postavkama kako biste preskočili potvrde brisanja."

#. TRANSLATORS: First-start hint for Linux users shown in
#. the log on the main screen.
#: ../bleachbit/GuiStartup.py
msgid ""
"Access the application menu by clicking the hamburger icon on the title bar."
msgstr "Izborniku aplikacije pristupite klikom na ikonu izbornika u naslovnoj traci."

#. TRANSLATORS: First-start hint for Windows users shown in
#. the log on the main screen.
#: ../bleachbit/GuiStartup.py
msgid "Access the application menu by clicking the logo on the title bar."
msgstr "Izborniku aplikacije pristupite klikom na logotip u naslovnoj traci."

#. TRANSLATORS: Warning shown on startup when running BleachBit as root on Linux.
#. It means, for example, that cleaning a browser will clean root's browser data.
#: ../bleachbit/GuiStartup.py
msgid ""
"You are running BleachBit with administrative privileges for cleaning shared "
"parts of the system, and references to the user profile folder will clean "
"only the root account."
msgstr "Pokrenuli ste BleachBit s administratorskim ovlastima radi čišćenja zajedničkih dijelova sustava, a reference na mapu korisničkog profila očistit će samo račun root."

#. TRANSLATORS: Warning shown on startup on Windows.
#: ../bleachbit/GuiStartup.py
msgid ""
"Run BleachBit with administrator privileges to improve the accuracy of "
"overwriting the contents of files."
msgstr "Pokrenite BleachBit s administratorskim ovlastima kako biste poboljšali točnost prebrisivanja sadržaja datoteka."

#. TRANSLATORS: Warning shown on startup on Windows when elevated
#. with different account. It means, for example, that cleaning a
#. browser will clean the browser data of the administrator account.
#: ../bleachbit/GuiStartup.py
msgid ""
"You elevated privileges using a different account to clean shared parts of "
"the system. User-specific paths will refer to the administrator account, so "
"to clean your profile, run BleachBit again as a standard user."
msgstr "Povisili ste ovlasti pomoću drugog računa radi čišćenja zajedničkih dijelova sustava. Putanje specifične za korisnika odnosit će se na administratorski račun, pa za čišćenje vlastitog profila ponovno pokrenite BleachBit kao standardni korisnik."

#. TRANSLATORS: Warning shown on startup on Windows when running
#. unofficial Microsoft Store version. Advises user to get genuine
#. version from official website.
#: ../bleachbit/GuiStartup.py
msgid ""
"There is no official version of BleachBit on the Microsoft Store. Get the "
"genuine version at https://www.bleachbit.org where it is always free of "
"charge."
msgstr "Ne postoji službena verzija BleachBita u Microsoft Storeu. Preuzmite autentičnu verziju na https://www.bleachbit.org, gdje je uvijek besplatna."

#. TRANSLATORS: Column header indicating whether the cleaner is active/enabled.
#. Used in the tree view on the main screen.
#: ../bleachbit/GuiTreeModels.py
msgid "Active"
msgstr "Aktivno"

#. TRANSLATORS: Column header for the size of the cleaner.
#. Used in the tree view on the main screen.
#. 'Size' is a noun and refers to the amount of space that the cleaner
