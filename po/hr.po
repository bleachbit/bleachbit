msgstr "%s se ne može očistiti jer je trenutačno pokrenut. Zatvorite ga i pokušajte ponovno."

#: ../bleachbit/Update.py
msgid "New winapp2.ini was downloaded."
msgstr "Preuzet je novi winapp2.ini."

#: ../bleachbit/Update.py
msgid "Update BleachBit"
msgstr "Ažuriraj BleachBit"

#: ../bleachbit/Update.py
msgid "A new version is available."
