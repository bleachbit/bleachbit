#. process ID; %(child_pid)d is the child process ID.
#: ../bleachbit/Memory.py
#, python-format
msgid ""
"The function wipe_memory() with process ID %(parent_pid)d is waiting for "
"child process ID %(child_pid)d."
msgstr "Funkcija wipe_memory() s ID-om procesa %(parent_pid)d čeka podređeni proces s ID-om %(child_pid)d."

#: ../bleachbit/Memory.py
#, python-format
msgid "The child memory-wiping process returned code %d."
msgstr "Podređeni proces za prebrisivanje memorije vratio je kôd %d."

#: ../bleachbit/Network.py
#, python-format
msgid "Downloading URL failed: %s"
msgstr "Preuzimanje URL-a nije uspjelo: %s"

#: ../bleachbit/Options.py
#, python-format
msgid "Disk was full when writing configuration to file: %s"
msgstr "Disk je bio pun pri zapisivanju konfiguracije u datoteku: %s"

#: ../bleachbit/Options.py
#, python-format
msgid "Permission denied when writing configuration to file: %s"
msgstr "Dozvola je odbijena pri zapisivanju konfiguracije u datoteku: %s"

#: ../bleachbit/Options.py
#, python-format
msgid "Error checking whether path exists: %s"
