#, python-format
msgid ""
"Wrote %(file_count)d files and %(total_bytes)d bytes in %(elapsed_sec)d "
"seconds at %(rate_mbs).2f MB/s"
msgstr ""
"Menulis %(file_count)d berkas dan %(total_bytes)d byte dalam %(elapsed_sec)d "
"detik pada %(rate_mbs).2f MB/d"

