msgstr "Fehler: {operation_option}: {command}"

#. TRANSLATORS: 'empty' means 'unallocated'
#: ../bleachbit/Worker.py
msgid "Please wait. Wiping empty space."
msgstr "Bitte warten. Nicht zugewiesener Speicherplatz wird gelöscht."

#: ../bleachbit/Worker.py
msgid "To stop this process, press the abort button on the toolbar and wait."
msgstr ""
"Um diesen Vorgang zu stoppen, drücken Sie die Schaltfläche Abbrechen in der "
"Symbolleiste und warten Sie."

#: ../bleachbit/Worker.py
msgid ""
"If the application is force closed before the process is complete, large "
"files may remain on the disk, and they may use all available space. To "
"remove them, start BleachBit again."
msgstr ""
"Wenn die Anwendung vor Abschluss des Vorgangs zwangsweise geschlossen wird, "
"können große Dateien auf der Festplatte verbleiben und den gesamten "
"verfügbaren Speicherplatz belegen. Um sie zu entfernen, starten Sie "
"BleachBit erneut."

#. TRANSLATORS: %s is replaced with Firefox, System, etc.
#: ../bleachbit/Worker.py
#, python-format
msgid "Please wait.  Cleaning %s."
msgstr "Bitte warten. %s wird bereinigt."

#: ../bleachbit/Worker.py
#, python-format
msgid "About %d minute remaining."
msgid_plural "About %d minutes remaining."
msgstr[0] "Noch %d Minute verbleibend."
msgstr[1] "Noch %d Minuten verbleibend."

#. TRANSLATORS: This refers to disk space that was
#. really recovered (in other words, not a preview)
#: ../bleachbit/Worker.py
#, python-format
msgid "Disk space recovered: %s"
msgstr "Wiedergewonnener Speicherplatz: %s"

