msgstr "Zugriff verweigert beim Markieren der Datei zum späteren Löschen: %s"

#: ../bleachbit/Worker.py
#, python-format
msgid "Access denied when deleting registry value: %s"
msgstr "Zugriff verweigert beim Löschen des Registrierungswerts: %s"

#: ../bleachbit/Worker.py
#, python-format
msgid "Access denied when deleting registry key: %s"
msgstr "Zugriff verweigert beim Löschen des Registrierungsschlüssels: %s"

#: ../bleachbit/Worker.py
#, python-format
msgid "Access denied: %s"
msgstr "Zugriff verweigert: %s"

