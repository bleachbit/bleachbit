#: ../bleachbit/Worker.py
#, python-format
msgid ""
"%s cannot be cleaned because it is currently running.  Close it, and try "
"again."
msgstr ""
"%s ne peut être nettoyé car celui-ci est en cours d’exécution. Fermez ce "
"logiciel, puis réessayez."

#. TRANSLATORS: 'free' means 'unallocated'
#: ../bleachbit/Worker.py
msgid "Please wait.  Wiping free disk space."
msgstr ""
"Veuillez patienter. L’écrasement de l’espace disque libre est en cours."

#: ../bleachbit/Worker.py
msgid ""
"Wiping free disk space erases remnants of files that were deleted without "
"shredding. It does not free up space."
msgstr ""
"L'effacement de l'espace disque libre efface les restes de fichiers qui ont "
"été supprimés sans être détruits. Cela ne libère pas d'espace."

#. TRANSLATORS: %s is replaced with Firefox, System, etc.
#: ../bleachbit/Worker.py
