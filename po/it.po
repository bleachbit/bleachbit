"overwriting."
msgstr ""
"In un file system era presente almeno un file che non supporta la "
"sovrascrittura avanzata."

#. TRANSLATORS: Debug log message shown during file wiping. 'Wiping' is a
#. present participle (ongoing action). %(pathname)s is the file/directory
#. path; %(fstype)s is the file system type (e.g., ext3, ntfs).
#. Do not translate variables.
#: ../bleachbit/Wipe.py
#, python-format
msgid "Wiping path %(pathname)s with file system type %(fstype)s"
msgstr ""
"Cancellazione del percorso %(pathname)s con il tipo di file system %(fstype)s"

#: ../bleachbit/Wipe.py
#, python-format
msgid "Path to wipe must be an existing directory: %s"
msgstr "Il percorso da pulire deve essere una cartella esistente: %s"

