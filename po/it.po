msgstr "Percorso protetto"

#. TRANSLATORS: Noun used as a column header in the preferences dialog.
#: ../bleachbit/GuiPreferences.py
msgid "File"
msgstr "File"

#. TRANSLATORS: Noun used as a column header in the preferences dialog.
