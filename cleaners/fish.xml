Ubuntu Resolute Racoon (26.04 LTS)
fish, version 4.2.1
has ~/.local/share/fish/fish_history

"fish" is lowercase even at the beginning of a sentence.
https://fishshell.com/
https://github.com/fish-shell/fish-shell
-->
<cleaner id="fish" os="unix">
  <label>fish</label>
  <description>Shell</description>
  <option id="history">
    <label>History</label>
    <description>Delete the command history</description>
    <action command="delete" search="file" path="~/.local/share/fish/fish_history"/>
  </option>
</cleaner>
