<cleaner id="snap" os="linux">
  <label>snap</label>
  <description>Package manager</description>
  <!-- No <running> check: the per-user "snap userd" daemon is always
       running for logged-in users and does not conflict with
       "snap remove". -->
  <option id="disabled">
    <label>Disabled</label>
    <description>Remove disabled packages</description>
    <action command="snap.disabled"/>
  </option>
</cleaner>
