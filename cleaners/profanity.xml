<cleaner id="profanity" os="unix">
  <label>Profanity</label>
  <description>Chat client</description>
  <option id="downloads">
    <label>Downloaded files</label>
    <description>Delete the files</description>
    <action command="delete" search="walk.files" path="~/.local/share/profanity/downloads/"/>
  </option>
  <option id="logs">
    <label>Logs</label>
    <description>Delete the logs</description>
    <action command="delete" search="walk.files" path="~/.local/share/profanity/logs/"/>
  </option>
</cleaner>
