macOS Tahoe (26)
zsh 5.9 (arm64-apple-darwin25.0)
has ~/.zsh_history
has ~/.zsh_sessions : macOS specific feature

Ubuntu Resolution Racoon (26.04 LTS)
zsh 5.9 (x86_64-ubuntu-linux-gnu)
has ~/.zsh_history
does not have ~/.zsh_sessions

The name (proper noun) is written usually "Zsh" and "Z shell,"
"ZSH," and "Z SHELL." Even when not referring to the command, it may
be lowercase "zsh.""
https://www.zsh.org/

-->
<cleaner id="zsh" os="unix">
  <label>Zsh</label>
  <description>Shell</description>
  <option id="history">
    <label>History</label>
    <description>Delete the command history</description>
    <action command="delete" search="file" path="~/.zsh_history"/>
  </option>
  <option id="session" os="darwin">
    <label>Session</label>
    <description>Delete the files</description>
    <action command="delete" search="walk.all" path="~/.zsh_sessions/"/>
  </option>
</cleaner>
