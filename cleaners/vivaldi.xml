<?xml version="1.0" encoding="UTF-8"?>
<!--
    BleachBit CleanerML - Vivaldi Browser
    @url https://vivaldi.com
    @tested ok vivaldi-6.x, Windows 10/11, Linux, macOS
    @note Covers Default profile; for additional profiles, duplicate var 'profile'
-->
<cleaner id="vivaldi">
  <label>Vivaldi</label>
  <description>Web browser</description>
  <!-- Detect running process -->
  <running type="exe" os="windows" same_user="true">vivaldi.exe</running>
  <running type="exe" os="linux" same_user="true">vivaldi</running>
  <running type="exe" os="darwin" same_user="true">Vivaldi</running>
  <!-- Base user-data directory -->
  <var name="base">
    <value os="windows">%LOCALAPPDATA%\Vivaldi\User Data</value>
    <value os="linux">$XDG_CONFIG_HOME/vivaldi</value>
    <value os="linux">~/.config/vivaldi</value>
    <value os="linux">~/snap/vivaldi/current/.config/vivaldi</value>
    <value os="darwin">$HOME/Library/Application Support/Vivaldi</value>
  </var>
  <!-- Default profile directory -->
  <var name="profile">
    <value os="windows">%LOCALAPPDATA%\Vivaldi\User Data\Default</value>
    <value os="linux">$XDG_CONFIG_HOME/vivaldi/Default</value>
    <value os="linux">~/.config/vivaldi/Default</value>
    <value os="linux">~/snap/vivaldi/current/.config/vivaldi/Default</value>
    <value os="darwin">$HOME/Library/Application Support/Vivaldi/Default</value>
  </var>
  <!-- Cache -->
  <option id="cache">
    <label>Cache</label>
    <description>Delete the web cache, which reduces time to display revisited pages</description>
    <action search="walk.files" command="delete" path="~/snap/vivaldi/common/.cache/"/>
    <action search="walk.files" command="delete" path="$$profile$$/Code Cache"/>
    <action search="walk.files" command="delete" path="$$profile$$/GPUCache"/>
    <action search="walk.files" command="delete" path="$$base$$/ShaderCache"/>
    <action search="walk.files" command="delete" path="$$base$$/GrShaderCache"/>
    <action search="walk.files" command="delete" path="$$base$$/GraphiteDawnCache"/>
    <action search="walk.files" command="delete" path="$$base$$/component_crx_cache"/>
    <action search="walk.files" command="delete" path="$$base$$/extensions_crx_cache"/>
  </option>
  <!-- Cookies -->
  <option id="cookies">
    <label>Cookies</label>
    <description>Delete cookies, which contain information such as website preferences, authentication, and tracking identification</description>
    <action command="cookie" search="file" path="$$profile$$/Cookies"/>
    <action command="delete" search="file" path="$$profile$$/Cookies-journal"/>
  </option>
  <!-- Browsing history -->
  <option id="history">
    <label>History</label>
    <description>Delete the history which includes visited sites, downloads, and thumbnails</description>
    <action command="chrome.history" search="file" path="$$profile$$/History"/>
    <action search="file" command="delete" path="$$profile$$/History Provider Cache"/>
    <action search="file" command="delete" path="$$profile$$/Top Sites"/>
    <action search="file" command="delete" path="$$profile$$/Visited Links"/>
  </option>
  <!-- Web storage (LocalStorage, IndexedDB, SessionStorage) -->
  <option id="site_data">
    <label>Site data</label>
    <description>Delete LocalStorage, IndexedDB, and other data stored by websites</description>
    <action search="walk.all" command="delete" path="$$profile$$/Local Storage"/>
    <action search="walk.all" command="delete" path="$$profile$$/IndexedDB"/>
    <action search="walk.all" command="delete" path="$$profile$$/Session Storage"/>
    <action search="walk.all" command="delete" path="$$profile$$/WebStorage"/>
  </option>
</cleaner>
